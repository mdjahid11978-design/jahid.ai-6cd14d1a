# Server Configuration
PORT=5000
NODE_ENV=development
API_BASE_URL=http://localhost:5000

# Database
MONGODB_URI=mongodb://localhost:27017/jahid-ai
DB_NAME=jahid-ai

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# API Keys
